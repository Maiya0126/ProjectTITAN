		<tradeTags>
			<li>TitanImplant</li>
		</tradeTags>
		<thingCategories>
			<li>Medicine</li>
		</thingCategories>
		<graphicData>
			<texPath>Things/Item/Health/HealthItem</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>0.8</drawSize>
		</graphicData>
		<statBases>
			<WorkToMake>20000</WorkToMake>
