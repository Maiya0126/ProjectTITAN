	<ThingDef ParentName="TitanMutagenBase">
		<defName>TITAN_Implant_CrimsonHeart</defName>
		<label>猩红诱变剂</label>
		<description>利用战争之痕基因制造的猩红药剂。\n\n【用法】：\n请在敲击兽的“健康 -> 手术”面板中选择“喂食 猩红诱变剂”。\n\n效果：无痛觉、大幅提升近战伤害。</description>
		<costList>
			<Plasteel>20</Plasteel>
			<ComponentSpacer>1</ComponentSpacer>
			<TITAN_PrototypeScale>1</TITAN_PrototypeScale>
		</costList>
		<recipeMaker>
			<researchPrerequisite>TITAN_Tech_Destroyer</researchPrerequisite>
		</recipeMaker>
		<ingestible>
			<outcomeDoers>
				<li Class="ProjectTITAN.IngestionOutcomeDoer_TitanMutation">
					<hediffDef>TITAN_Implant_CrimsonHeart</hediffDef>
				</li>
			</outcomeDoers>
		</ingestible>
	</ThingDef>

