<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<HediffDef>
		<defName>TITAN_GeneticDrift</defName>
		<label>基因漂移</label>
		<description>42号实验体的基因正在缓慢偏移，导致精神恍惚和间歇性行动中断。只有0号原型体的泰坦共鸣才能将其修正。</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(150, 180, 255)</defaultLabelColor>
		<isBad>true</isBad>
		<stages>
			<li>
				<statOffsets>
					<MoveSpeed>-1.0</MoveSpeed>
					<PsychicSensitivity>-0.5</PsychicSensitivity>
				</statOffsets>
				<capMods>
					<li><capacity>Consciousness</capacity><offset>-0.2</offset></li>
				</capMods>
			</li>
		</stages>
	</HediffDef>

	<HediffDef>
		<defName>TITAN_No88_BurnTrauma</defName>
		<label>火焰创伤</label>
		<description>88号实验体从一场森林大火中逃离时遭受的严重烧伤。共生真菌网络大面积枯死，需要时间再生。</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(200, 120, 50)</defaultLabelColor>
		<isBad>true</isBad>
		<stages>
			<li>
				<statOffsets>
					<MoveSpeed>-0.8</MoveSpeed>
				</statOffsets>
				<painOffset>0.3</painOffset>
			</li>
		</stages>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>600000</disappearsAfterTicks>
				<showRemainingTime>true</showRemainingTime>
			</li>
		</comps>
	</HediffDef>

</Defs>