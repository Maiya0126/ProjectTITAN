<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<HediffDef>
		<defName>TITAN_GeneticCollapse</defName>
		<label>基因崩溃</label>
		<description>基因组正在解离。</description>

		<hediffClass>HediffWithComps</hediffClass>

		<lethalSeverity>1.0</lethalSeverity>
		<makesSickThought>true</makesSickThought>
		<stages>
			<li>
				<label>初期</label>
				<painOffset>0.1</painOffset>
			</li>
			<li>
				<minSeverity>0.6</minSeverity>
				<label>危急</label>
				<painOffset>0.3</painOffset>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<offset>-0.3</offset>
					</li>
				</capMods>
			</li>
		</stages>
		<comps>
			<li Class="HediffCompProperties_SeverityPerDay">
				<severityPerDay>0.10</severityPerDay>
			</li>
		</comps>
	</HediffDef>

	<HediffDef>
		<defName>TITAN_VoidAnchor</defName>
		<label>相位锚定</label>
		<description>暂时无法闪避。</description>

		<hediffClass>HediffWithComps</hediffClass>

		<defaultLabelColor>(0.8, 0.8, 1.0)</defaultLabelColor>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>600~1200</disappearsAfterTicks>
				<showRemainingTime>true</showRemainingTime>
			</li>
		</comps>
		<stages>
			<li>
				<statOffsets>
					<MeleeDodgeChance>-50.0</MeleeDodgeChance>
					<MoveSpeed>-0.5</MoveSpeed>
				</statOffsets>
			</li>
		</stages>
	</HediffDef>

	<ThoughtDef>
		<defName>TITAN_ResonanceMood</defName>
		<durationDays>1</durationDays>
		<stackLimit>1</stackLimit>
		<stages>
			<li>
				<label>泰坦共鸣</label>
				<description>0号原型体的灵能波让我感到无比平静。</description>
				<baseMoodEffect>10</baseMoodEffect>
			</li>
		</stages>
	</ThoughtDef>

	<HediffDef>
		<defName>TITAN_TitanReinforcementBuff</defName>
		<label>泰坦庇护</label>
		<description>泰坦神兽的力量暂时注入体内，生命与攻击大幅强化。</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(1.0, 0.85, 0.3)</defaultLabelColor>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>150000</disappearsAfterTicks>
				<showRemainingTime>true</showRemainingTime>
			</li>
		</comps>
		<stages>
			<li>
				<statOffsets>
					<MeleeDamageFactor>2.0</MeleeDamageFactor>
				</statOffsets>
				<statFactors>
					<IncomingDamageFactor>0.5</IncomingDamageFactor>
				</statFactors>
			</li>
		</stages>
	</HediffDef>

	<HediffDef>
		<defName>TITAN_RoyalMark</defName>
		<label>王权印记</label>
		<description>0号原型体以皇室血脉标记的臣属，全属性获得强化。</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(1.0, 0.84, 0.0)</defaultLabelColor>
		<stages>
			<li>
				<statFactors>
					<MoveSpeed>1.15</MoveSpeed>
					<MeleeDamageFactor>1.15</MeleeDamageFactor>
					<IncomingDamageFactor>0.85</IncomingDamageFactor>
				</statFactors>
			</li>
		</stages>
	</HediffDef>

</Defs>