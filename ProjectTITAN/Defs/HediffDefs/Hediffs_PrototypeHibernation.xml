<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<HediffDef>
		<defName>TITAN_PrototypeHibernation</defName>
		<label>强制休眠中</label>
		<description>0号原型体受到致命伤害，自我保护机制已启动强制休眠。\n\n状态：\n- 强制休眠（无法唤醒）\n- 极速自我修复\n- 免疫绝大多数伤害\n- 60秒后自动苏醒</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(255, 215, 0)</defaultLabelColor>
		<isBad>false</isBad>

		<stages>
			<li>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<setMax>0.01</setMax>
					</li>
				</capMods>
				<naturalHealingFactor>100.0</naturalHealingFactor>
				<statOffsets>
					<IncomingDamageFactor>0</IncomingDamageFactor>
				</statOffsets>
			</li>
		</stages>

		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>60000</disappearsAfterTicks>
				<showRemainingTime>true</showRemainingTime>
			</li>
		</comps>
	</HediffDef>
</Defs>
