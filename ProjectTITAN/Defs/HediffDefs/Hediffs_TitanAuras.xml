<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<HediffDef>
		<defName>TITAN_Aura_Warlord</defName>
		<label>血之狂怒</label>
		<description>受到战争之痕的狂暴影响。</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(255, 50, 50)</defaultLabelColor>
		<isBad>false</isBad>
		<stages>
			<li>
				<statOffsets>
					<MeleeDPS>0.5</MeleeDPS>
					<ShootingAccuracyPawn>5</ShootingAccuracyPawn>
				</statOffsets>
			</li>
		</stages>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>120</disappearsAfterTicks>
				<showRemainingTime>false</showRemainingTime>
			</li>
			<li Class="ProjectTITAN.HediffCompProperties_HealthDrain">
				<damageAmount>1</damageAmount>
				<intervalSeconds>15.0</intervalSeconds>
			</li>
		</comps>
	</HediffDef>

	<HediffDef>
		<defName>TITAN_Aura_Warlord_Source</defName>
		<label>战争之痕光环</label>
		<description>正在散发狂暴的灵能波动。</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(255, 50, 50)</defaultLabelColor>
		<isBad>false</isBad>
		<stages>
			<li></li>
		</stages>
	</HediffDef>

	<HediffDef>
		<defName>TITAN_Aura_VoidWalker</defName>
		<label>虚空帷幕</label>
		<description>受到虚空行者的相位保护。</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(100, 230, 255)</defaultLabelColor>
		<isBad>false</isBad>
		<stages>
			<li>
				<statOffsets>
					<MeleeDodgeChance>30</MeleeDodgeChance>
					<ArmorRating_Sharp>0.3</ArmorRating_Sharp>
					<ArmorRating_Blunt>0.3</ArmorRating_Blunt>
				</statOffsets>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<offset>-0.10</offset>
					</li>
				</capMods>
			</li>
		</stages>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>120</disappearsAfterTicks>
				<showRemainingTime>false</showRemainingTime>
			</li>
		</comps>
	</HediffDef>

	<HediffDef>
		<defName>TITAN_Aura_VoidWalker_Source</defName>
		<label>虚空行者光环</label>
		<description>正在散发扭曲相位的灵能。</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(100, 230, 255)</defaultLabelColor>
		<isBad>false</isBad>
		<stages>
			<li></li>
		</stages>
	</HediffDef>

	<HediffDef>
		<defName>TITAN_Aura_Matriarch</defName>
		<label>生命绽放</label>
		<description>沐浴在生命光辉中。</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(120, 255, 120)</defaultLabelColor>
		<isBad>false</isBad>
		<stages>
			<li>
				<statOffsets>
					<MoveSpeed>1.0</MoveSpeed>
					<ImmunityGainSpeed>0.5</ImmunityGainSpeed>
				</statOffsets>
				<naturalHealingFactor>5.0</naturalHealingFactor>
			</li>
		</stages>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>120</disappearsAfterTicks>
				<showRemainingTime>false</showRemainingTime>
			</li>
		</comps>
	</HediffDef>

	<HediffDef>
		<defName>TITAN_Aura_Matriarch_Source</defName>
		<label>繁盛之母光环</label>
		<description>正在散发生命能量。</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(120, 255, 120)</defaultLabelColor>
		<isBad>false</isBad>
		<stages>
			<li></li>
		</stages>
	</HediffDef>
	<HediffDef>
		<defName>TITAN_WarlordSoothing</defName>
		<label>泰坦共鸣(安抚中)</label>
		<description>0号原型体的灵能正在尝试平息它的怒火。当共鸣层数达到 3 层时，它将停止攻击。</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(255, 200, 100)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<stages>
			<li>
				<minSeverity>0.0</minSeverity>
				<label>共鸣 I</label>
				<statOffsets>
					<MoveSpeed>-0.5</MoveSpeed>
				</statOffsets>
			</li>
			<li>
				<minSeverity>0.35</minSeverity>
				<label>共鸣 II</label>
				<statOffsets>
					<MoveSpeed>-1.5</MoveSpeed>
				</statOffsets>
			</li>
			<li>
				<minSeverity>0.9</minSeverity>
				<label>共鸣完成</label>
			</li>
		</stages>
		<comps>
			<li Class="HediffCompProperties_SeverityPerDay">
				<severityPerDay>-0.5</severityPerDay>
			</li>
		</comps>
	</HediffDef>

</Defs>