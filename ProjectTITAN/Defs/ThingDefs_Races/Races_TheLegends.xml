<Defs>



	<ThingDef ParentName="AnimalThingBase">
		<defName>TITAN_Warlord</defName>
		<label>战争之痕</label>
		<description>传说中的三大神兽之一。年龄：未知(远古)。\n\n特性：\n- 不死之身\n- 光环：血之狂怒</description>
		<statBases>
			<MoveSpeed>6.0</MoveSpeed>
			<MarketValue>6000</MarketValue>
			<ComfyTemperatureMin>-100</ComfyTemperatureMin>
			<ArmorRating_Sharp>0.90</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.80</ArmorRating_Blunt>
			<FilthRate>20</FilthRate>
			<Wildness>2.0</Wildness>
		</statBases>
		<race>
			<body>QuadrupedAnimalWithHoovesAndHorn</body>
			<baseBodySize>6.0</baseBodySize>
			<baseHealthScale>10.0</baseHealthScale>
			<foodType>VegetarianRoughAnimal, DendrovoreAnimal</foodType>
			<useMeatFrom>Thrumbo</useMeatFrom>
			<lifeExpectancy>150</lifeExpectancy>
			<lifeStageAges>
				<li>
					<def>AnimalAdult</def>
					<minAge>0</minAge>
					<soundWounded>Pawn_Thrumbo_Pain</soundWounded>
					<soundDeath>Pawn_Thrumbo_Death</soundDeath>
					<soundCall>Pawn_Thrumbo_Call</soundCall>
					<soundAngry>Pawn_Thrumbo_Angry</soundAngry>
				</li>
</lifeStageAges>
		</race>
		<comps>
			<!--<li Class="CompProperties_Glower">
				<glowRadius>8</glowRadius>
				<glowColor>(255, 20, 20, 0)</glowColor>
			</li>-->

			<li Class="CompProperties">
				<compClass>ProjectTITAN.CompMobileLight</compClass>
			</li>
			<li Class="ProjectTITAN.CompProperties_TitanAura">
				<radius>12</radius>
				<buffDef>TITAN_Aura_Warlord</buffDef>
				<selfBuffDef>TITAN_Aura_Warlord_Source</selfBuffDef>
				<selfDamage>false</selfDamage>
			</li>
		</comps>
		<tools>
			<li>
				<label>shattering horn</label>
				<capacities>
					<li>Poke</li>
				</capacities>
				<power>60</power>
				<cooldownTime>3.0</cooldownTime>
				<linkedBodyPartsGroup>HornAttackTool</linkedBodyPartsGroup>
			</li>
		</tools>
	</ThingDef>

