<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<ThingDef ParentName="AnimalThingBase">
		<defName>TITAN_ThrumboPrototype</defName>
		<label>0号原型体</label>
		<description>帝国异种生物研究部“泰坦计划”的最终产物。它的皮毛呈现出淡淡的金色，那是皇室基因的象征。\n\n它拥有强大的自我修复能力，无法被彻底杀死（只会倒地）。\n\n特性：\n- 定期脱落【金色鳞片】\n- 成年后会吸引野生敲击兽\n- 主动技能：泰坦共鸣</description>

		<statBases>
			<MoveSpeed>6.0</MoveSpeed>
			<MarketValue>3000</MarketValue>
			<ComfyTemperatureMin>-60</ComfyTemperatureMin>
			<FilthRate>8</FilthRate>
			<Wildness>0.1</Wildness>
		</statBases>

		<race>
			<body>QuadrupedAnimalWithHoovesAndHorn</body>
			<baseBodySize>2.0</baseBodySize>
			<baseHealthScale>3.0</baseHealthScale>
			<lifeExpectancy>200</lifeExpectancy>
			<trainability>Advanced</trainability>
			<baseHungerRate>1.5</baseHungerRate>
			<foodType>VegetarianRoughAnimal, DendrovoreAnimal</foodType>
			<useMeatFrom>Thrumbo</useMeatFrom>
			<petness>1</petness><nameOnTameChance>1</nameOnTameChance>

			<lifeStageAges>
				<li>
					<def>AnimalBaby</def>
					<minAge>0</minAge>
				</li>
				<li>
					<def>AnimalJuvenile</def>
					<minAge>0.5</minAge>
				</li>
				<li>
					<def>AnimalAdult</def>
					<minAge>2.0</minAge>
					<soundWounded>Pawn_Thrumbo_Pain</soundWounded>
					<soundDeath>Pawn_Thrumbo_Death</soundDeath>
					<soundAngry>Pawn_Thrumbo_Angry</soundAngry>
					<soundCall>Pawn_Thrumbo_Call</soundCall>
				</li>
			</lifeStageAges>
			<specialTrainables>
				<li MayRequire="Ludeon.RimWorld.Odyssey">ThrumboRoar</li>
			</specialTrainables>
		</race>

		<comps>
			<li Class="ProjectTITAN.CompProperties_TitanBond">
				<targetPawnKind>TITAN_Spark</targetPawnKind>
				<bondHediff>TITAN_Bond_Thrumbo</bondHediff>
				<range>15</range>
			</li>
			<li Class="ProjectTITAN.CompProperties_TitanBond">
				<targetPawnKind>TITAN_No26_ToyThrumbo</targetPawnKind>
				<bondHediff>TITAN_Bond_No26_Protected</bondHediff>
				<range>50</range>
			</li>
			<li Class="CompProperties_Spawner">
				<thingToSpawn>TITAN_PrototypeScale</thingToSpawn>
				<spawnCount>1</spawnCount>
				<spawnIntervalRange>900000~1200000</spawnIntervalRange>
				<writeTimeLeftToSpawn>true</writeTimeLeftToSpawn>
				<showMessageIfOwned>true</showMessageIfOwned>
			</li>
			<!--<li Class="CompProperties_Glower">
				<glowRadius>3</glowRadius>
				<glowColor>(255, 220, 100, 0)</glowColor>
			</li>-->
			<li Class="CompProperties">
				<compClass>ProjectTITAN.CompMobileLight</compClass>
			</li>
			<li Class="CompProperties">
				<compClass>ProjectTITAN.CompThrumboMagnet</compClass>
			</li>
			<li Class="ProjectTITAN.CompProperties_TitanAbility">
				<cooldownDays>0.04</cooldownDays>
				<healAmount>20</healAmount>
				<range>40</range>
			</li>
		</comps>

		<tools>
			<li>
				<label>horn</label>
				<capacities>
					<li>Scratch</li>
					<li>Poke</li>
				</capacities>
				<power>18</power>
				<cooldownTime>2.0</cooldownTime>
				<linkedBodyPartsGroup>HornAttackTool</linkedBodyPartsGroup>
			</li>
			<li>
				<label>teeth</label>
				<capacities>
					<li>Bite</li>
				</capacities>
				<power>12</power>
				<cooldownTime>2.0</cooldownTime>
				<linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
				<chanceFactor>0.7</chanceFactor>
			</li>
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2.0</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
				<chanceFactor>0.2</chanceFactor>
			</li>
		</tools>
	</ThingDef>

