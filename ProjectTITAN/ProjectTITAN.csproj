    <PostBuildEvent>REM ================================================================
REM  【泰坦计划 - 终极同步脚本】
REM  1. 同步 XML/图片/关于信息
REM  2. 自动提取并复制 DLL
REM ================================================================

REM --- 设置游戏 Mod 目录 (请确保路径无误) ---
set "DestDir=D:\games\steamapps\common\Rimworld\Mods\MaiyaMod06 Project T.I.T.A.N. 泰坦计划"

REM --- 1. 同步静态资源 (XML, About, Textures) ---
REM 直接使用 VS 宏 $(ProjectDir)，不需要 cd 跳来跳去
REM /MIR: 镜像同步 (会自动删除目标文件夹里多余的旧垃圾)
echo 正在同步静态资源...
robocopy "$(ProjectDir)." "%25DestDir%25" /MIR ^
  /XD .git .vs obj bin Properties Source .idea ^
  /XF *.csproj *.sln *.user *.suo PublishedFileId.txt *.cs

REM --- 2. 这里的 Robocopy 返回值处理 (这很重要，否则 VS 会以为出错了) ---
if %25ERRORLEVEL%25 LEQ 8 set ERRORLEVEL=0

REM --- 3. 关键：手动复制 DLL ---
REM 如果没有 Assemblies 文件夹，先创建一个
if not exist "%25DestDir%25\Assemblies" mkdir "%25DestDir%25\Assemblies"

REM 从生成目录 (TargetDir) 把 DLL 拷过去
echo 正在部署 DLL 核心...
copy /Y "$(TargetDir)$(TargetName).dll" "%25DestDir%25\Assemblies\"
copy /Y "$(TargetDir)$(TargetName).pdb" "%25DestDir%25\Assemblies\"

REM --- 4. 结束 ---
echo [泰坦计划] 部署完成！
exit 0</PostBuildEvent>
